# GEMINI_API_KEY: Required for server-side Gemini API calls.
# Never expose this in frontend code or client bundles.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Optional override for Gemini model
GEMINI_MODEL="gemini-3.1-pro-preview"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---------------------------
# Contact Form Backend Config
# ---------------------------

# Express server port
PORT=5000

# Comma-separated list of allowed origins for CORS.
# Use "*" only in local/testing environments.
CORS_ORIGIN="http://localhost:3000"

# Optional Vite dev proxy target (frontend -> backend)
VITE_API_PROXY_TARGET="http://localhost:5000"

# SMTP auth credentials (required)
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"

# Pick one SMTP mode:
# 1) Service mode (e.g., Gmail, Outlook)
# SMTP_SERVICE="gmail"
#
# 2) Host/Port mode
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false

# Contact email routing
CONTACT_TO_EMAIL="your-email@example.com"
CONTACT_FROM_EMAIL="no-reply@example.com"

# Basic rate limit protection for POST /api/contact
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX=5

# Basic rate limit protection for AI endpoints
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX=20
